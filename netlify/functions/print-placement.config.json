  "sweatshirt":          { "placement": "front", "position": { "area_width": null, "area_height": null, "width": null, "height": null, "top": null, "left": null, "limit_to_print_area": true } },
  "hoodie":              { "placement": "front", "position": { "area_width": null, "area_height": null, "width": null, "height": null, "top": null, "left": null, "limit_to_print_area": true } },
